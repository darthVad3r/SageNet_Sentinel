{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MLNet": {
    "ModelPath": "fraud_model.zip"
  },
  "SageMaker": {
    "Enabled": false,
    "EndpointName": "fraud-detection-endpoint",
    "RoleArn": "TODO: platform-team to provide IAM role ARN",
    "S3BucketName": "TODO: platform-team to provide bucket",
    "AwsRegion": "us-west-2"
  },
  "FalsePositiveReduction": {
    "MLNetWeight": 0.5,
    "SageMakerWeight": 0.5,
    "FraudThreshold": 0.5,
    "DisagreementThreshold": 0.7,
    "SmallTransactionThreshold": 50.0,
    "HighValueTransactionThreshold": 5000.0,
    "LowConfidenceThreshold": 0.3,
    "MinimumConfidenceForAutoDecision": 0.4
  },
  "Grpc": {
    "Enabled": true,
    "Port": 5001,
    "SecureChannel": false,
    "TODO": "platform-team: mTLS + service registry integration"
  },
  "Kinesis": {
    "Enabled": false,
    "StreamName": "sagenet-transactions",
    "BatchSize": 25,
    "PollIntervalSeconds": 5,
    "TODO": "platform-team: IAM roles, credentials, AWS runtime configuration"
  },
  "Observability": {
    "TracingEnabled": true,
    "MetricsEnabled": true,
    "TODO": "platform-team: exporter endpoints and telemetry backend configuration"
  }
}
